  <widget class="QPushButton" name="btn_skinDefault">
   <property name="geometry">
    <rect>
     <x>50</x>
     <y>920</y>
     <width>190</width>
     <height>66</height>
    </rect>
   </property>
   <property name="font">
    <font>
     <pointsize>-1</pointsize>
     <italic>false</italic>
     <bold>true</bold>
    </font>
   </property>
   <property name="styleSheet">
    <string notr="true">QPushButton {
    border: 2px solid #b285e6;
    border-radius: 18px;
    min-width: 155px;
    min-height: 62px;
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
    stop:0 #7996dd,stop:0.3 #9483d1,stop:0.6 #bb82bc,stop:1 #c992a5);
    color: #2c2057;
    font: bold 19px;
    padding: 0px; /* 为按压效果做准备 */
}

/* 鼠标悬浮效果 (Hover) - 提亮发光 */
QPushButton:hover {
    /* 1. 边框变成高亮的淡紫色，模拟发光 */
    border: 3px solid #d8b4ff; 
    
    /* 2. 背景渐变整体调亮一个色阶，产生被点亮的感觉 */
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
    stop:0 #8faaf0,stop:0.3 #a998e6,stop:0.6 #d498d5,stop:1 #e0a7ba);
    
    /* 3. 字体变成纯白，增加对比度 */
    color: #ffffff; 
}

/* 鼠标按下效果 (Pressed) - 物理下压反馈 */
QPushButton:pressed {
    /* 背景变暗，模拟背光被手遮挡 */
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
    stop:0 #6885cc,stop:0.3 #8372c0,stop:0.6 #aa71ab,stop:1 #b88194);
    
    /* 核心物理感：利用 padding 把文字往下挤，产生凹陷错觉 */
    padding-top: 4px;
    padding-bottom: -4px;
    border: 2px solid #b285e6; /* 边框恢复正常 */
}</string>
   </property>
   <property name="text">
    <string>🏐坚强期末周小球</string>
   </property>
  </widget>
